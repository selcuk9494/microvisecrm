{
  "name": "@istakip/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "App.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "build:ios": "eas build -p ios --profile production",
    "submit:ios": "ASC_APP_ID=${ASC_APP_ID} eas submit -p ios --latest --non-interactive --asc-app-id $ASC_APP_ID",
    "release:ios": "eas build -p ios --profile production --non-interactive && ASC_APP_ID=${ASC_APP_ID} eas submit -p ios --latest --non-interactive --asc-app-id $ASC_APP_ID"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.2.3",
    "expo": "^51.0.11",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-web": "^0.19.13",
    "react-native-webview": "13.8.6"
  },
  "devDependencies": {
    "babel-preset-expo": "^11.0.11",
    "eas-cli": "^18.4.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
